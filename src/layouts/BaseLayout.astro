---
/* =============================================================================
   BaseLayout.astro — the single layout every page is wrapped in.
   =============================================================================

   WHAT IS A LAYOUT IN ASTRO?
   A layout is just an .astro component that renders the shared shell — the
   <html>/<head>/<body>, site-wide <head> tags, and common chrome like the nav
   and footer — then drops the page's unique content into a <slot />.
   Pages (src/pages/*.astro) import this and put their content between the
   <BaseLayout> tags.

   THE FRONTMATTER (this `---` fenced block) runs at BUILD TIME on the server.
   It's plain TypeScript. Nothing here ships to the browser unless we explicitly
   put it inside a <script>. That's the core Astro idea: zero JS by default.
============================================================================= */

import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

// Props let a page customize the per-page SEO bits. We give sensible defaults
// so most pages don't have to pass anything.
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Daryll Banal — research analyst & aspiring data engineer",
  description = "I build data-driven insights and interactive dashboards.",
} = Astro.props;

// Astro.site comes from `site` in astro.config.mjs. new URL(..., Astro.site)
// builds absolute URLs, which Open Graph / Twitter cards require.
const ogImage = new URL("/og.png", Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Facebook, LinkedIn, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!--
      NO-FLASH THEME SCRIPT.
      `is:inline` tells Astro to leave this script exactly as written and inject
      it as-is, so it runs SYNCHRONOUSLY in <head> BEFORE the page paints.
      That prevents a "flash of the wrong theme" on load:
        1. If the user previously chose a theme, use it (localStorage).
        2. Otherwise fall back to their OS preference (prefers-color-scheme).
      The theme toggle island (added next step) reads/writes the same key.
    -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          const prefersLight =
            window.matchMedia("(prefers-color-scheme: light)").matches;
          const theme = stored ?? (prefersLight ? "light" : "dark");
          // Dark is the default (no attribute); only set the attribute for light.
          if (theme === "light") {
            document.documentElement.setAttribute("data-theme", "light");
          }
        } catch (e) {
          /* localStorage may be unavailable (e.g. privacy mode) — ignore. */
        }
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col">
    <!--
      Skip link: lets keyboard/screen-reader users jump straight to content,
      bypassing the nav. Visually hidden until focused.
    -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-accent focus:px-4 focus:py-2 focus:text-on-accent"
    >
      Skip to content
    </a>

    <!-- Site-wide navigation. -->
    <Nav />

    <!-- Main page content. Pages render here via the default <slot />. -->
    <main id="main" class="flex-1">
      <slot />
    </main>

    <!-- Site-wide footer. -->
    <Footer />
  </body>
</html>
