---
/* =============================================================================
   Hero.astro — the top-of-page introduction.
   =============================================================================
   Static (no JS). A faint engineered line-grid sits behind the content at very
   low opacity, faded out toward the bottom with a CSS mask so it blends into
   the page. The headline accents its last two words via a <span>.
============================================================================= */

// The three mono "proof" chips. Kept as data so they're easy to tweak.
const proofChips = [
  "python + sql pipelines",
  "power bi + streamlit",
  "postgresql modeling",
];

const githubUrl = "https://github.com/DaryllBanal1030";
---

<section
  class="relative overflow-hidden"
  aria-labelledby="hero-heading"
>
  <!-- Faint line-grid motif. `grid-motif` (from global.css) draws the lines;
       the mask fades them out toward the bottom so there's no hard edge.
       aria-hidden because it's purely decorative. -->
  <div
    class="grid-motif absolute inset-0 -z-10 [mask-image:linear-gradient(to_bottom,black,transparent_85%)]"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-6xl px-6 pb-16 pt-24 sm:pb-24 sm:pt-32">
    <!-- Mono eyebrow. -->
    <p
      class="font-mono text-sm uppercase tracking-[0.2em] text-accent"
      data-reveal
    >
      research analyst · aspiring data engineer
    </p>

    <!-- Headline. The last two words are wrapped in an accent span. -->
    <h1
      id="hero-heading"
      class="mt-6 max-w-4xl font-sans text-4xl font-bold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl"
      data-reveal
    >
      I turn messy market data into dashboards and <span class="text-accent"
        >downloadable datasets</span
      >.
    </h1>

    <!-- Subline. -->
    <p class="mt-6 max-w-2xl text-lg text-muted" data-reveal>
      Research analyst at PRIME Philippines, building Python and SQL data
      pipelines and moving into data engineering.
    </p>

    <!-- Proof chips: mono pills. -->
    <ul class="mt-8 flex flex-wrap gap-3" data-reveal>
      {
        proofChips.map((chip) => (
          <li class="rounded-md border border-border bg-surface/50 px-3 py-1.5 font-mono text-xs text-muted">
            {chip}
          </li>
        ))
      }
    </ul>

    <!-- Buttons: full width on mobile, inline from sm up. -->
    <div class="mt-10 flex flex-col gap-3 sm:flex-row" data-reveal>
      <a
        href="#work"
        class="rounded-md bg-accent px-6 py-3 text-center text-sm font-medium text-on-accent transition-opacity hover:opacity-90"
      >
        View work
      </a>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-md border border-border px-6 py-3 text-center text-sm font-medium text-text transition-colors hover:border-accent hover:text-accent"
      >
        <!-- GitHub mark. -->
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.05-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.2-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.82 0c2.22-1.49 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.75.81 1.2 1.84 1.2 3.1 0 4.43-2.7 5.41-5.26 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5z"
          ></path>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</section>
