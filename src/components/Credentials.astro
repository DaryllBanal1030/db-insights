---
/* =============================================================================
   Credentials.astro — one flat grid sourced from the credentials collection.
   =============================================================================
   Like the carousel, this reads from a content collection: add a .md file to
   src/content/credentials/ and it appears here automatically. Rendered as a
   single flat list (not bucketed), sorted by `order`.
============================================================================= */

import Section from "./Section.astro";
import { getCollection } from "astro:content";

const credentials = (await getCollection("credentials")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Section id="credentials" index={5} label="certifications & achievements">
  <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      credentials.map((cred) => {
        const { title, issuer, year, tag, verifyUrl } = cred.data;
        return (
          <li class="flex flex-col rounded-xl border border-border bg-surface p-5">
            <div class="flex items-start justify-between gap-3">
              <h3 class="font-semibold leading-snug tracking-tight">{title}</h3>
              {tag && (
                <span class="shrink-0 rounded-md border border-hairline px-2 py-0.5 font-mono text-[10px] uppercase tracking-wide text-muted">
                  {tag}
                </span>
              )}
            </div>
            <p class="mt-2 text-sm text-muted">
              {issuer} · <span class="font-mono text-faint">{year}</span>
            </p>
            {verifyUrl && (
              <a
                href={verifyUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center gap-1 self-start font-mono text-xs text-accent transition-opacity hover:opacity-80"
              >
                Verify ↗
              </a>
            )}
          </li>
        );
      })
    }
  </ul>
</Section>
