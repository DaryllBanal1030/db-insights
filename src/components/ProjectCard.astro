---
/* =============================================================================
   ProjectCard.astro — one project, rendered from a collection entry's data.
   =============================================================================
   This is a pure presentational component: give it the project `data` object
   and it draws the card. It's used inside the carousel, but could be reused in
   any grid later without changes.
============================================================================= */

import type { CollectionEntry } from "astro:content";

interface Props {
  // The validated frontmatter of one projects-collection entry.
  project: CollectionEntry<"projects">["data"];
}

const { project } = Astro.props;
const { title, status, summary, tags, liveUrl, repoUrl } = project;

// Map each status to its badge styling (dot + text color). These are functional
// status colors, intentionally separate from the single decorative accent.
const statusStyles: Record<typeof status, { dot: string; text: string }> = {
  Live: { dot: "bg-live", text: "text-live" },
  "In progress": { dot: "bg-amber-400", text: "text-amber-400" },
  Concept: { dot: "bg-faint", text: "text-faint" },
};
const badge = statusStyles[status];
---

<article
  class="flex h-full flex-col rounded-xl border border-border bg-surface p-6 sm:p-8"
>
  <!-- Header: title + status badge. -->
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-sans text-xl font-semibold tracking-tight">{title}</h3>
    <span
      class={`inline-flex shrink-0 items-center gap-2 rounded-full border border-border px-3 py-1 font-mono text-xs ${badge.text}`}
    >
      <span class={`h-1.5 w-1.5 rounded-full ${badge.dot}`} aria-hidden="true"
      ></span>
      {status}
    </span>
  </div>

  <!-- The brief blurb. -->
  <p class="mt-4 text-muted">{summary}</p>

  <!-- Tech tags as mono pills. -->
  <ul class="mt-6 flex flex-wrap gap-2">
    {
      tags.map((tag) => (
        <li class="rounded-md border border-hairline px-2.5 py-1 font-mono text-xs text-muted">
          {tag}
        </li>
      ))
    }
  </ul>

  <!-- Links pinned to the bottom (mt-auto) so cards line up at equal height.
       External links open in a new tab with safe rel attributes. -->
  <div class="mt-auto flex flex-wrap gap-3 pt-8">
    <a
      href={liveUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-on-accent transition-opacity hover:opacity-90"
    >
      Visit site ↗
    </a>
    {
      repoUrl && (
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md border border-border px-4 py-2 text-sm font-medium text-text transition-colors hover:border-accent hover:text-accent"
        >
          Code ↗
        </a>
      )
    }
  </div>
</article>
