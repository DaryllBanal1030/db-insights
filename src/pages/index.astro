---
/* =============================================================================
   index.astro — the single page of this site.
   =============================================================================
   Pages live in src/pages/. index.astro -> route "/". This page composes the
   section components in order. More sections (hero, about, etc.) get added in
   later steps.
============================================================================= */

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import Carousel from "../components/Carousel.astro";
import DBLearningBand from "../components/DBLearningBand.astro";
import About from "../components/About.astro";
import Experience from "../components/Experience.astro";
import Skills from "../components/Skills.astro";
import Credentials from "../components/Credentials.astro";
import Contact from "../components/Contact.astro";
---

<BaseLayout>
  <!-- Hero: top-of-page intro with the grid motif. -->
  <Hero />

  <!-- 01 — Featured work: the carousel, sourced from the projects collection. -->
  <Section id="work" index={1} label="featured work">
    <Carousel />
  </Section>

  <!-- DBLearning: a distinct branded band (no section number — separate venture). -->
  <DBLearningBand />

  <!-- 02 — About: intro, photo, and the Gather → Store → Analyze → Present flow. -->
  <About />

  <!-- 03 — Experience: vertical timeline. -->
  <Experience />

  <!-- 04 — Skills: four grouped cards. -->
  <Skills />

  <!-- 05 — Credentials: flat grid from the credentials collection. -->
  <Credentials />

  <!-- 06 — Contact: real email + social links. -->
  <Contact />
</BaseLayout>
