---
/* =============================================================================
   index.astro — the single page of this site.
   =============================================================================
   Pages live in src/pages/. index.astro -> route "/". This page composes the
   section components in order. More sections (hero, about, etc.) get added in
   later steps.
============================================================================= */

import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Carousel from "../components/Carousel.astro";
---

<BaseLayout>
  <!-- 01 — Featured work: the carousel, sourced from the projects collection. -->
  <Section id="work" index={1} label="featured work">
    <Carousel />
  </Section>
</BaseLayout>
